{
    "name": "infocyph/game-draw",
    "description": "Generates Item and Item count for winners.",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "abmmhasan",
            "email": "abmmhasan@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-bcmath": "*",
        "psr/cache": "^3.0"
    },
    "require-dev": {
        "infocyph/phpforge": "dev-main"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Infocyph\\Draw\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infocyph/phpforge": true,
            "pestphp/pest-plugin": true
        },
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
